{
  "name": "@speca11y/cli",
  "version": "0.2.0",
  "description": "CLI for SpecA11y - automated WCAG accessibility checker",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "speca11y": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@speca11y/core": "workspace:*",
    "commander": "^13.0.0",
    "picocolors": "^1.1.0"
  },
  "peerDependencies": {
    "playwright": "^1.40.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "playwright": "^1.50.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  },
  "license": "MIT"
}
